# git-vacuum environment configuration
#
# Copy this file to `.env` and fill in your values:
#   cp .env.example .env
#
# .env is gitignored. Never commit it.

# ─── GitHub Personal Access Token (PAT) ──────────────────────────────
# Used when you want to skip the auth screen entirely.
# Create one at: https://github.com/settings/tokens
# Required scopes: repo, read:org, user
GITHUB_TOKEN=

# ─── GitHub OAuth App client_id (browser sign-in) ────────────────────
# 1. Register an OAuth App at:
#      https://github.com/settings/applications/new
# 2. Settings:
#      Application name: git-vacuum (or whatever you like)
#      Homepage URL:      http://localhost
#      Authorization callback URL: http://localhost (device flow doesn't
#        actually use this, but GitHub requires the field)
# 3. After registering, copy the "Client ID" value (looks like: Iv1.abc123def456)
# 4. Paste it below, OR pass via flag: --oauth-client-id <id>
# 5. The client_secret is NOT required for the device authorization flow.
#    Leave it blank even though GitHub shows you one.
GIT_VACUUM_OAUTH_CLIENT_ID=

# ─── Database location (optional) ────────────────────────────────────
# Defaults to %LOCALAPPDATA%\git-vacuum\db.sqlite on Windows,
# ~/.local/share/git-vacuum/db.sqlite on Linux/macOS.
# GIT_VACUUM_DB=

# ─── Clone destination (optional) ────────────────────────────────────
# Defaults to ~/git-vacuum
# GIT_VACUUM_CLONE_PATH=
